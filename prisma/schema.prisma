generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model School {
  id        String   @id @default(uuid())
  name      String
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users     UserSchool[]
  invites   UserInvite[]
  students  Student[]
  classes   Class[]

  @@map("schools")
}

model Class {
  id        String   @id @default(uuid())
  grade     String
  section   String
  shift     String
  academicYear Int   @default(2026) @map("academic_year")
  schoolId  String   @map("school_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students  Student[]
  enrollments StudentEnrollment[]

  @@unique([schoolId, grade, section, shift, academicYear])
  @@map("classes")
}

model User {
  id        String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  isGlobalAdmin Boolean @default(false) @map("is_global_admin")
  lastActiveAt DateTime? @map("last_active_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  schools              UserSchool[]
  readingRecords      StudentReadingHistory[]
  sessions            UserSession[]
  auditLogs           AuditLog[]
  createdInvites      UserInvite[] @relation("InviteCreator")

  @@map("users")
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  token        String   @unique
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("user_sessions")
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  action      String   
  details     Json?    
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model UserSchool {
  userId    String @map("user_id")
  schoolId String @map("school_id")
  role     String @default("TEACHER")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@id([userId, schoolId])
  @@map("user_schools")
}

model UserInvite {
  id          String    @id @default(uuid())
  name        String
  email       String
  role        String
  schoolId    String    @map("school_id")
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  school    School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy User   @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([schoolId])
  @@map("user_invites")
}

model Student {
  id            String   @id @default(uuid())
  name          String
  studentNumber String   @map("student_number")
  schoolId      String   @map("school_id")
  classId       String   @map("class_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  school           School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class            Class                    @relation(fields: [classId], references: [id], onDelete: Cascade)
  enrollments      StudentEnrollment[]
  readingHistory   StudentReadingHistory[]

  @@unique([studentNumber, schoolId])
  @@map("students")
}

model StudentEnrollment {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  classId   String   @map("class_id")
  startedAt DateTime @map("started_at")
  endedAt   DateTime? @map("ended_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  readingHistory StudentReadingHistory[]

  @@index([studentId])
  @@index([classId])
  @@map("student_enrollments")
}

model ReadingLevel {
  id          String @id @default(uuid())
  name        String
  code        String @unique
  order       Int
  description String?

  history StudentReadingHistory[]

  @@map("reading_levels")
}

model StudentReadingHistory {
  id              String   @id @default(uuid())
  studentId       String   @map("student_id")
  enrollmentId    String   @map("enrollment_id")
  readingLevelId  String   @map("reading_level_id")
  userId          String  @map("user_id")
  recordedAt      DateTime @default(now()) @map("recorded_at")
  createdAt       DateTime @default(now()) @map("created_at")
  notes           String?

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrollment   StudentEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  readingLevel ReadingLevel @relation(fields: [readingLevelId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("student_reading_history")
}
